# ============================================
# DATABASE (Supabase PostgreSQL)
# ============================================
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================
# SERVER
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# CORS & FRONTEND
# Isi domain Vercel frontend di sini
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ============================================
# JWT & SECURITY
# ============================================
JWT_SECRET=your_super_secret_jwt_key_here

# ============================================
# WHATSAPP (Fonnte fallback — optional)
# WA Client (whatsapp-web.js) sudah terintegrasi di backend
# Fonnte hanya dipakai sebagai fallback jika WA Client tidak aktif
# ============================================
WHATSAPP_API_URL=https://api.fonnte.com/send
WHATSAPP_API_KEY=your_fonnte_api_key

# ============================================
# GOOGLE CONTACTS (OAuth 2.0)
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/google/callback

# ============================================
# MAIL (Optional — untuk forgot password)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
