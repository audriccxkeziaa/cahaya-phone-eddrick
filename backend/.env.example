# ============================================
# DATABASE CONFIGURATION (PostgreSQL / Supabase)
# ============================================
# The app + migrate.js connect via DATABASE_URL only. Copy the connection
# string from Supabase: Project → Settings → Database → Connection string (URI).
# Use the Session/Transaction Pooler URI. SSL is required.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# NOTE: the DB_* vars below are LEGACY (MySQL era) and are NOT read by the code.
# Kept only for reference — DATABASE_URL above is the single source of truth.
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=cahaya_phone_crm

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# CORS & FRONTEND URLs
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
FRONTEND_URL=http://localhost:5500

# ============================================
# WHATSAPP BRIDGE (Baileys self-hosted — gratis)
# wa-bridge di-deploy sebagai service terpisah di Railway.
# URL ini adalah internal URL dari Railway (pakai .railway.internal)
# atau URL public HTTPS kalau sudah di-expose.
# ============================================
WA_BRIDGE_URL=http://localhost:3001
WA_BRIDGE_SECRET=ganti-dengan-secret-random-yang-kuat

# ============================================
# SYNC SECRET (untuk quick-sync contacts, kirim via header X-Sync-Key)
# ============================================
SYNC_SECRET=your_random_sync_secret_here

# ============================================
# MAIL CONFIGURATION (Optional)
# Used for "Forgot Password" email reset.
#
# Recommended: port 465 (implicit TLS) instead of 587 (STARTTLS).
# On Railway, 465 connects more reliably; 587 sometimes hangs at TCP handshake.
# When MAIL_PORT=465, MAIL_SECURE auto-derives to true unless overridden.
#
# For Gmail: enable 2FA, then generate an App Password (not the regular password):
#   https://myaccount.google.com/apppasswords
# ============================================
# MAIL_USER/MAIL_FROM = the Gmail that SENDS reset emails. Use the same account
# the owner receives reset links on (admins.email), e.g. cahayaphone288@gmail.com.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=cahayaphone288@gmail.com
MAIL_PASS=your_16char_app_password
MAIL_FROM=cahayaphone288@gmail.com
# MAIL_SECURE=true       # optional override; auto-derived from MAIL_PORT

# ============================================
# RAILWAY BILLING REMINDER (Optional)
# Day of the month when Railway auto-charges the card. Used by the admin
# dashboard banner that warns the owner H-3, H-2, H-1, H, and up to H+2.
# Default 11 (Hobby plan signup date).
# ============================================
BILLING_DAY=11

# ============================================
# JWT & SECURITY
# ============================================
# JWT_SECRET MUST be at least 32 characters of high entropy. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Server will refuse to start if this is missing, too short, or still the example value.
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Cookie SameSite policy. Set to "none" ONLY if frontend is on a DIFFERENT origin
# than backend (e.g. admin on Vercel + backend on Railway). Cookies will then
# use SameSite=None; Secure (requires HTTPS). Default = "lax" for same-origin.
# COOKIE_SAMESITE=lax

# NODE_ENV controls strictness: when "production" the server requires ALLOWED_ORIGINS
# and WA_BRIDGE_SECRET to be set, and won't log full webhook bodies (PII).
# NODE_ENV=production

# ============================================
# STATUS EXPIRY
# ============================================
STATUS_EXPIRE_HOURS=24
STATUS_OLD_LABEL=Old

# ============================================
# GOOGLE CONTACTS API
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-domain.com/api/google/callback