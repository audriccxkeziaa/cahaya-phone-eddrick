# WA Bridge Configuration
PORT=3001

# Secret key untuk autentikasi (HARUS SAMA dengan WA_BRIDGE_SECRET di backend service)
WA_BRIDGE_SECRET=cahaya-phone-secret-key

# URL webhook backend utama (untuk forward pesan masuk).
# - Local dev:     http://localhost:5000/api/webhook/whatsapp
# - Railway internal (RECOMMENDED — gak kena bandwidth, gak exposed publik):
#   http://backend.railway.internal:5000/api/webhook/whatsapp
# - Railway public (kurang aman, fallback):
#   https://your-backend.railway.app/api/webhook/whatsapp
WEBHOOK_URL=

# WhatsApp session storage. WAJIB persistent supaya gak perlu scan QR ulang
# tiap kali container restart. Di Railway: buat Volume di dashboard, mount ke
# /data, lalu set SESSION_DIR=/data/wa-session. Local dev: biarkan default.
SESSION_DIR=./wa-session
